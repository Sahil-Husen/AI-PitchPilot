  "bugs": {
    "url": "https://github.com/Sahil-Husen/AI-PitchPilot/issues"
  },
  "homepage": "https://github.com/Sahil-Husen/AI-PitchPilot#readme",
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
